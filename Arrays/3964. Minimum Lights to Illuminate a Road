class Solution {
    public String[] createGrid(int m, int n) {
        String[][] res = new String[m][n];
        for(String i[]: res){
            Arrays.fill(i, "#");
        }
        for(int i=0; i<n; i++){
            res[0][i] = ".";
        }
        for(int i=0; i<m; i++){
            res[i][n-1] = ".";
        }
        String[] r = new String[m];
        for(int i=0; i<m; i++){
            StringBuilder s = new StringBuilder();
            for(int j=0; j<n; j++){
                s.append(res[i][j]);
            }
            r[i] = s.toString();
        }
        return r;
    }
}
