class Solution {
    public long pickGifts(int[] gifts, int k) {
        PriorityQueue<Integer> q = new PriorityQueue<>(Collections.reverseOrder());
        int n = gifts.length;
        for(int i=0; i<n; i++){
            q.add(gifts[i]);
        }
        while(k > 0){
            long curr = q.poll();
            q.add((int)Math.floor(Math.sqrt(curr)));
            k--;
        }
        long sum=0;
        while(!q.isEmpty()){
            sum += q.poll();
        }
        return sum;
    }
}
