class Solution {
    public int minimumRecolors(String blocks, int k) {
        HashMap<Character, Integer> map = new HashMap<>();
        int n = blocks.length();
        int min = Integer.MAX_VALUE;
        map.put('W', 0);
        map.put('B', 0);
        for(int i=0; i<k; i++){
            char c = blocks.charAt(i);
            map.put(c, map.get(c)+1);
        }
        min = Math.min(min, map.get('W'));
        for(int i=k; i<n; i++){
            char c = blocks.charAt(i-k);
            map.put(c, map.get(c)-1);
            map.put(blocks.charAt(i), map.get(blocks.charAt(i))+1);
            min = Math.min(min, map.get('W'));
        }
        return min;
    }
}
