class KthLargest {
    PriorityQueue<Integer> max;
    int plug;

    public KthLargest(int k, int[] nums) {
        max = new PriorityQueue<>(Collections.reverseOrder());
        for(int i: nums){
            max.add(i);
        }
        plug = k;
    }
    
    public int add(int val) {
        int j=1;
        for(int num: max){
            if(plug == j){
                return num;
            }
            j++;
        }
        max.add(val);
        return 0;
    }
}

