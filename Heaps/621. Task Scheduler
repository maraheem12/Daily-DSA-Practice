class Solution {
    public int leastInterval(char[] tasks, int n) {
        int freq[] = new int[26];

        for(char c : tasks){
            freq[c - 'A']++;
        }

        PriorityQueue<Integer> pq =
            new PriorityQueue<>((a,b) -> b - a);

        for(int f : freq){
            if(f > 0) pq.offer(f);
        }

        int time = 0;

        while(!pq.isEmpty()){

            List<Integer> list = new ArrayList<>();
            int cycle = n + 1;

            while(cycle > 0 && !pq.isEmpty()){

                int curr = pq.poll();
                curr--;

                if(curr > 0){
                    list.add(curr);
                }

                time++;
                cycle--;
            }

            for(int x : list){
                pq.offer(x);
            }

            if(pq.isEmpty()) break;

            time += cycle;
        }

        return time;
    }
}
