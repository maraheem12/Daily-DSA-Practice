class Solution {
    public int maxDistance(String moves) {
        int x = 0, y = 0, blank = 0;

        for (char c : moves.toCharArray()) {
            if (c == 'U') y++;
            else if (c == 'D') y--;
            else if (c == 'R') x++;
            else if (c == 'L') x--;
            else blank++;
        }

        return Math.abs(x) + Math.abs(y) + blank;
    }
}
