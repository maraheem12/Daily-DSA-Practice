class Solution {
    public int solve(int[] nums, int target, int idx, int n, int dp[]) {
        if(dp[idx] != -1){
            return dp[idx];
        }
        if (idx == n - 1) {
            return 0;
        }

        int maxi = Integer.MIN_VALUE;

        for (int j = idx + 1; j < n; j++) {
            if (Math.abs(nums[j] - nums[idx]) <= target) {
                maxi = Math.max(maxi, 1 + solve(nums, target, j, n, dp));
            }
        }

        return dp[idx] = maxi;
    }
    public int maximumJumps(int[] nums, int target) {
        int n = nums.length;
        int dp[] = new int[n+1];
        Arrays.fill(dp, -1);
        int ans = solve(nums, target, 0, n, dp);
        return ans <= 0 ? -1 : ans;
    }
}


















