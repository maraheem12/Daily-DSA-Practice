class Solution {
    public int cost(int[] cost, int n, int idx, int[] dp){
        if(idx >= n){
            return 0;
        }
        if(dp[idx] != -1){
            return dp[idx];
        }
        int step1 = cost[idx] + cost(cost, n, idx+1, dp);
        int step2 = cost[idx] + cost(cost, n, idx+2, dp);

        return dp[idx] = Math.min(step1, step2);
    }
    public int minCostClimbingStairs(int[] cost) {
        int n = cost.length;
        int dp[] = new int[n+1];
        Arrays.fill(dp, -1);
        int min = Math.min(cost(cost, n, 0, dp), cost(cost, n, 1, dp));
        return min;
    }
}
